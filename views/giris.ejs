<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Giriş Yap - Teknik Servis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light d-flex align-items-center min-vh-100">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            
            <div class="card border-0 shadow-lg overflow-hidden">
                
                <div class="card-header text-center p-4" style="background: var(--secondary-color); color: white;">
                    <div class="fs-1 mb-2">🔐</div>
                    <h4 class="fw-bold m-0">Giriş Yap</h4>
                    <small class="opacity-75">Hesabınıza erişim sağlayın</small>
                </div>

                <div class="card-body p-4">
                    <% if (mesaj) { %>
                        <div class="alert alert-danger text-center shadow-sm border-0"><%= mesaj %></div>
                    <% } %>

                    <form action="/giris" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">E-posta Adresi</label>
                            <input type="email" name="email" class="form-control form-control-lg" placeholder="ornek@mail.com" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary small">Şifre</label>
                            <input type="password" name="sifre" class="form-control form-control-lg" placeholder="******" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Giriş Yap</button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-white text-center p-3 border-0">
                    <p class="small mb-2 text-muted">Henüz hesabın yok mu? <a href="/kayit" class="fw-bold text-primary text-decoration-none">Hemen Kayıt Ol</a></p>
                    <a href="/" class="small text-muted text-decoration-none hover-link">← Ana Sayfaya Dön</a>
                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>