<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Yeni Konu Aç</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Yeni Konu Başlat</h4>
                    </div>
                    <div class="card-body p-4">
                        <form action="/forum/yeni" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Konu Başlığı</label>
                                <input type="text" name="baslik" class="form-control" placeholder="Örn: Telefonum suya düştü, ne yapmalıyım?" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">İçerik / Sorunuz</label>
                                <textarea name="icerik" class="form-control" rows="6" placeholder="Detayları buraya yazınız..." required></textarea>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success">Yayınla</button>
                                <a href="/forum" class="btn btn-secondary">İptal</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>