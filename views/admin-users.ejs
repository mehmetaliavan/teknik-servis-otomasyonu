<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Admin - Kullanıcı Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">
    <h1 class="fw-bold text-primary mb-4">Admin Paneli</h1>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item"><a class="nav-link text-dark" href="/admin">🛠️ Arıza Talepleri</a></li>
        <li class="nav-item"><a class="nav-link active fw-bold" href="/admin/users">👥 Kullanıcılar</a></li>
    </ul>

    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal" onclick="temizleModal()">
            + Yeni Kullanıcı Ekle
        </button>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Email / Rol</th>
                        <th>İletişim</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <% kullanicilar.forEach(user => { %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.ad_soyad %></td>
                            <td>
                                <%= user.email %><br>
                                <span class="badge bg-<%= user.rol=='admin'?'danger':'secondary' %>"><%= user.rol %></span>
                            </td>
                            <td><small><%= user.telefon || '-' %></small></td>
                            <td>
                                <button class="btn btn-sm btn-warning" 
                                    onclick="duzenle('<%= user.id %>', '<%= user.ad_soyad %>', '<%= user.email %>', '<%= user.rol %>', '<%= user.telefon %>', '<%= user.adres %>')">
                                    Düzenle
                                </button>
                                <a href="/admin/user-delete/<%= user.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Emin misiniz?')">Sil</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/user-save" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Kullanıcı Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="userId">
                    <div class="mb-2"><label>Ad Soyad</label><input type="text" name="ad_soyad" id="adSoyad" class="form-control" required></div>
                    <div class="mb-2"><label>Email</label><input type="email" name="email" id="email" class="form-control" required></div>
                    <div class="mb-2"><label>Şifre (Boş bırakırsan değişmez)</label><input type="password" name="sifre" class="form-control"></div>
                    <div class="mb-2"><label>Telefon</label><input type="text" name="telefon" id="telefon" class="form-control"></div>
                    <div class="mb-2"><label>Adres</label><textarea name="adres" id="adres" class="form-control"></textarea></div>
                    <div class="mb-2">
                        <label>Rol</label>
                        <select name="rol" id="rol" class="form-select">
                            <option value="user">User (Normal)</option>
                            <option value="admin">Admin (Yönetici)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function duzenle(id, ad, mail, rol, tel, adr) {
        document.getElementById('modalTitle').innerText = 'Kullanıcı Düzenle';
        document.getElementById('userId').value = id;
        document.getElementById('adSoyad').value = ad;
        document.getElementById('email').value = mail;
        document.getElementById('rol').value = rol;
        document.getElementById('telefon').value = tel;
        document.getElementById('adres').value = adr;
        new bootstrap.Modal(document.getElementById('userModal')).show();
    }
    function temizleModal() {
        document.getElementById('modalTitle').innerText = 'Yeni Kullanıcı';
        document.getElementById('userId').value = '';
        document.querySelector('form').reset();
    }
</script>
</body>
</html>