<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Cihaz Takip</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Teknik Servis</a>
        <a href="/ariza-birak" class="btn btn-warning btn-sm fw-bold">
            <i class="bi bi-plus-circle me-1"></i>Yeni Kayıt
        </a>
    </div>
</nav>

<div class="container">
    <div class="d-flex align-items-center mb-4">
        <div class="display-6 me-3 text-secondary"><i class="bi bi-list-check"></i></div>
        <h2 class="fw-bold m-0" style="color: var(--secondary-color);">Cihaz Takip Ekranı</h2>
    </div>
    
    <div class="row">
        <% if (kayitlar.length > 0) { %>
            <% kayitlar.forEach(function(kayit) { %>
                <div class="col-12 mb-4">
                    <div class="card shadow-lg border-0">
                        <div class="card-body p-4">
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="card-title fw-bold text-primary mb-0 fs-4">
                                    <i class="bi bi-phone me-2"></i><%= kayit.cihaz_tipi %>
                                </h5>
                                <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    <%= new Date(kayit.olusturma_tarihi).toLocaleDateString('tr-TR') %>
                                </span>
                            </div>
                            
                            <div class="bg-light p-3 rounded mb-4 border-start border-4 border-warning">
                                <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.7rem;">Arıza Açıklaması</small>
                                <span class="text-dark"><%= kayit.ariza_aciklamasi %></span>
                            </div>
                            
                            <hr class="text-muted opacity-25">

                            <div class="row align-items-center">
                                
                                <div class="col-md-5 mb-3 mb-md-0">
                                    <span class="fw-bold text-secondary me-2">Güncel Durum:</span>
                                    
                                    <% if(kayit.durum == 'beklemede') { %>
                                        <span class="badge bg-warning text-dark p-2">
                                            <i class="bi bi-search"></i> İnceleme Bekleniyor
                                        </span>
                                    
                                    <% } else if(kayit.durum == 'teklif_yapildi') { %>
                                        <span class="badge bg-info text-dark p-2">
                                            <i class="bi bi-currency-dollar"></i> Fiyat Teklifi Geldi
                                        </span>
                                    
                                    <% } else if(kayit.durum == 'onaylandi') { %>
                                        <span class="badge bg-primary p-2">
                                            <i class="bi bi-tools"></i> Onaylandı - Tamirde
                                        </span>
                                    
                                    <% } else if(kayit.durum == 'iptal') { %>
                                        <span class="badge bg-danger p-2">
                                            <i class="bi bi-x-circle"></i> İptal Edildi
                                        </span>

                                    <% } else { %>
                                        <span class="badge bg-success p-2">
                                            <i class="bi bi-check-circle-fill"></i> Tamamlandı
                                        </span>
                                    <% } %>
                                </div>
                                
                                <div class="col-md-7 text-md-end">
                                    
                                    <% if(kayit.durum === 'teklif_yapildi') { %>
                                        <div class="card bg-primary bg-opacity-10 border-primary">
                                            <div class="card-body p-3">
                                                <h5 class="fw-bold text-primary mb-2">💰 Fiyat Teklifi: <%= kayit.fiyat_teklifi %> TL</h5>
                                                <p class="small text-muted mb-3">Cihaz onarımı için belirlenen tutar. Onaylıyor musunuz?</p>
                                                
                                                <form action="/teklif-cevap" method="POST" class="d-flex justify-content-center gap-2">
                                                    <input type="hidden" name="kayit_id" value="<%= kayit.id %>">
                                                    <button type="submit" name="cevap" value="onaylandi" class="btn btn-sm btn-success fw-bold px-3">
                                                        <i class="bi bi-check-lg"></i> Kabul Et
                                                    </button>
                                                    <button type="submit" name="cevap" value="iptal" class="btn btn-sm btn-outline-danger fw-bold px-3">
                                                        <i class="bi bi-x-lg"></i> Reddet
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                    <% } else if(kayit.durum === 'onaylandi' && kayit.kargo_kodu) { %>
                                        
                                        <div class="d-flex gap-3 justify-content-end align-items-center flex-wrap">
                                            <div class="card border-success shadow-sm" style="min-width: 200px;">
                                                <div class="card-body p-2 d-flex align-items-center gap-2">
                                                    <div class="bg-success text-white rounded-circle p-2">
                                                        <i class="bi bi-telephone-fill"></i>
                                                    </div>
                                                    <div class="text-start">
                                                        <div class="small text-muted" style="font-size: 0.7rem;">TEKNİSYEN İLETİŞİM</div>
                                                        <div class="fw-bold text-success">0532 555 44 33</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="card bg-info bg-opacity-10 border-info d-inline-block text-start" style="min-width: 250px;">
                                                <div class="card-body p-2 text-center">
                                                    <div class="small text-uppercase fw-bold text-info mb-1" style="font-size: 0.7rem;">Ücretsiz Kargo Kodunuz</div>
                                                    <div class="fs-4 fw-bold font-monospace text-dark d-flex justify-content-center align-items-center">
                                                        <i class="bi bi-box-seam me-2"></i><%= kayit.kargo_kodu %>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="small text-muted mt-2 fst-italic text-end">
                                            * Sorularınız için yukarıdaki numaradan teknisyenimizle görüşebilirsiniz.
                                        </div>

                                    <% } else if (kayit.durum === 'beklemede') { %>
                                        <span class="text-muted small fst-italic">
                                            <i class="bi bi-info-circle me-1"></i>Teknisyenlerimiz cihazı inceliyor, yakında fiyat teklifi sunulacak.
                                        </span>

                                    <% } else if (kayit.durum === 'iptal') { %>
                                        <div class="text-danger small">
                                            Bu işlem iptal edilmiştir.
                                        </div>

                                    <% } else if (kayit.durum === 'tamamlandi') { %>
                                        <div class="text-success fw-bold">
                                            <i class="bi bi-emoji-smile-fill me-1"></i> Cihazınız hazır! Kargoya Verildi.
                                        </div>
                                    <% } %>
                                </div>

                            </div> </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-warning p-5 text-center shadow-sm">
                    <div class="display-1 text-warning mb-3"><i class="bi bi-exclamation-circle"></i></div>
                    <h4>Henüz bir arıza kaydınız yok.</h4>
                    <p>Cihazınız bozulduysa hemen yeni bir kayıt oluşturun.</p>
                    <a href="/ariza-birak" class="btn btn-warning fw-bold mt-2">Yeni Kayıt Oluştur</a>
                </div>
            </div>
        <% } %>
    </div>
</div>

</body>
</html>