<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Profilim</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-dark bg-dark mb-5">
    <div class="container">
        <a class="navbar-brand" href="/">Teknik Servis</a>
        <div class="ms-auto text-white">
            <span class="fw-bold"><%= user.ad_soyad %></span>
        </div>
    </div>
</nav>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center p-4">
                    <div class="display-4 mb-2"><i class="bi bi-person-circle"></i></div>
                    <h3 class="mb-0">Profil Bilgileri</h3>
                </div>
                <div class="card-body p-4">
                    
                    <% if (mesaj) { %>
                        <div class="alert alert-warning d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                            <div><%= mesaj %></div>
                        </div>
                    <% } %>

                    <form action="/profil" method="POST">
                        <div class="mb-3">
                            <label class="form-label text-muted">Ad Soyad</label>
                            <input type="text" class="form-control" value="<%= user.ad_soyad %>" disabled>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">E-posta</label>
                            <input type="text" class="form-control" value="<%= user.email %>" disabled>
                        </div>
                        
                        <hr class="my-4">
                        <h5 class="mb-3 text-primary">İletişim Bilgileri</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Telefon Numarası</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input type="text" name="telefon" class="form-control" placeholder="05XX XXX XX XX" value="<%= user.telefon || '' %>" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Adres</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                <textarea name="adres" class="form-control" rows="3" placeholder="Kargo için açık adresiniz..." required><%= user.adres || '' %></textarea>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-save me-2"></i>Bilgileri Güncelle
                            </button>
                            <a href="/" class="btn btn-outline-secondary">Ana Sayfaya Dön</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>