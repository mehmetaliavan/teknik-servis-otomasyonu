<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Teknik Servis - Profesyonel Çözümler</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <i class="bi bi-lightning-charge-fill text-warning"></i>
            <span>Yarrak Ali Avan TEKNİK SERVİS</span>
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="ms-auto d-flex align-items-center gap-3">
                
                <a href="/forum" class="btn btn-outline-light shadow-sm me-2">
                    <i class="bi bi-chat-quote-fill me-1"></i> Forum
                </a>

                <% if (user) { %>
                    <span class="text-white opacity-75">Merhaba, <strong><%= user.ad_soyad %></strong></span>
                    
                    <a href="/ariza-birak" class="btn btn-warning fw-bold text-dark shadow-sm">
                        <i class="bi bi-tools me-1"></i> Arıza Kaydı
                    </a>
                    
                    <a href="/takip" class="btn btn-outline-info text-white border-light shadow-sm">
                        <i class="bi bi-box-seam me-1"></i> Takip
                    </a>

                    <a href="/profil" class="btn btn-outline-light shadow-sm">
                        <i class="bi bi-person-circle me-1"></i> Profilim
                    </a>

                    <% if (user.rol === 'admin') { %>
                        <a href="/admin" class="btn btn-danger shadow-sm">Yönetim</a>
                    <% } %>
                    
                    <a href="/cikis" class="btn btn-outline-light btn-sm rounded-pill px-3">Çıkış</a>
                <% } else { %>
                    <a href="/giris" class="btn btn-outline-light rounded-pill px-4">Giriş Yap</a>
                    <a href="/kayit" class="btn btn-primary rounded-pill px-4 shadow-sm">Kayıt Ol</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<header class="hero-section d-flex align-items-center justify-content-center text-center text-white">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3 hero-title">Telefonunuz Emin Ellerde</h1>
        <p class="lead mb-4 opacity-75 fs-4">Ekran değişimi, batarya yenileme ve anakart onarımında uzman teknik servis.</p>
        
        <div class="d-flex justify-content-center gap-3">
            <% if (!user) { %>
                <a href="/kayit" class="btn btn-primary btn-lg px-5 py-3 shadow-lg">Hemen Başla</a>
                <a href="/giris" class="btn btn-outline-light btn-lg px-5 py-3">Giriş Yap</a>
            <% } else { %>
                <a href="/ariza-birak" class="btn btn-primary btn-lg px-5 py-3 shadow-lg">Arıza Kaydı Oluştur</a>
            <% } %>
        </div>
    </div>
</header>

<section class="container my-5 py-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 hover-scale">
                <div class="display-4 mb-3 text-primary"><i class="bi bi-speedometer2"></i></div>
                <h3>Hızlı Servis</h3>
                <p class="text-muted">Cihazlarınızı en kısa sürede analiz edip onarıyoruz.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 hover-scale">
                <div class="display-4 mb-3 text-success"><i class="bi bi-shield-check"></i></div>
                <h3>Garantili İşçilik</h3>
                <p class="text-muted">Yaptığımız tüm işlemlere 6 ay parça ve işçilik garantisi veriyoruz.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 bg-white shadow-sm h-100 hover-scale">
                <div class="display-4 mb-3 text-info"><i class="bi bi-person-gear"></i></div>
                <h3>Uzman Kadro</h3>
                <p class="text-muted">Alanında sertifikalı ve deneyimli teknisyenlerle çalışıyoruz.</p>
            </div>
        </div>
    </div>
</section>

<section class="container mb-5" id="calismalar">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: var(--secondary-color);">Son Yaptığımız İşler</h2>
        <p class="text-muted">Başarıyla onarılan cihazlardan bazı örnekler.</p>
    </div>

    <div class="row g-4">
        <% calismalar.forEach(function(calisma) { %>
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-lg overflow-hidden hover-card">
                    <img src="<%= calisma.resim_yolu ? calisma.resim_yolu : 'https://via.placeholder.com/400x300?text=Resim+Yok' %>" 
                         class="card-img-top" 
                         alt="<%= calisma.baslik %>"
                         style="height: 250px; object-fit: cover;">
                    
                    <div class="card-body">
                        <h5 class="card-title fw-bold"><%= calisma.baslik %></h5>
                        <p class="card-text text-muted small"><%= calisma.aciklama %></p>
                    </div>
                    
                    <div class="card-footer bg-white border-0 pb-3">
                        <a href="/calisma-detay/<%= calisma.id %>" class="btn btn-sm btn-outline-primary w-100 rounded-pill">
                            Detayları İncele <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        <% }); %>

        <% if (calismalar.length < 3) { %>
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-lg overflow-hidden hover-card">
                    <img src="/img/batarya.jpg" class="card-img-top" style="height: 250px; object-fit: cover;" alt="Batarya">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Batarya Değişimi</h5>
                        <p class="card-text text-muted small">Samsung S21 orijinal batarya değişimi ile pil ömrü uzatıldı.</p>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <button class="btn btn-sm btn-outline-secondary w-100 rounded-pill" disabled>Detaylar Yakında</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-lg overflow-hidden hover-card">
                    <img src="/img/tamir.jpg" class="card-img-top" style="height: 250px; object-fit: cover;" alt="Anakart">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Anakart Onarımı</h5>
                        <p class="card-text text-muted small">Sıvı teması sonrası oksitlenen anakart temizlenip kurtarıldı.</p>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <button class="btn btn-sm btn-outline-secondary w-100 rounded-pill" disabled>Detaylar Yakında</button>
                    </div>
                </div>
            </div>
        <% } %>

    </div>
</section>

<footer class="bg-dark text-white py-4 mt-5">
    <div class="container text-center">
        <p class="mb-0">&copy; 2025 Teknik Servis Projesi. Yarrak Ali Avan</p>
        <small class="opacity-50">okul numarası: 230525006</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>